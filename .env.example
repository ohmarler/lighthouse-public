# ============================================
# LIGHTHOUSE DASHBOARD - ENVIRONMENT VARIABLES
# ============================================
#
# This file contains ALL environment variables needed for full functionality.
# Copy this file to .env.local and fill in all values before deploying.
# Run: cp .env.example .env.local
#
# Complete Setup Guide: README.md
#
# Estimated setup time: 2 hours
# Estimated cost: $50 one-time + $5/month
#
# ============================================

# ============================================
# TARGET SITE
# ============================================
# The website you want to monitor

TARGET_BASE_URL=https://example.com
TARGET_DOMAIN=example.com
SITEMAP_URL=https://example.com/sitemap.xml

# ============================================
# DASHBOARD CONFIGURATION
# ============================================
# Where your dashboard is hosted

# Your Vercel deployment URL (or custom domain like lighthouse.example.com)
DASHBOARD_URL=https://your-project.vercel.app

# Same as DASHBOARD_URL (required by NextAuth)
NEXTAUTH_URL=https://your-project.vercel.app

# ============================================
# SECRETS
# ============================================
# Generate with: bash scripts/generate-secrets.sh (Mac/Linux)
#            or: powershell scripts/generate-secrets.ps1 (Windows)
#
# Or manually:
#   NEXTAUTH_SECRET: openssl rand -base64 32
#   CI_UPLOAD_SIGNING_KEY: openssl rand -hex 32

NEXTAUTH_SECRET=

# ⚠️  CRITICAL: Must be IDENTICAL in both locations:
#     1. Vercel environment variables
#     2. GitHub repository secrets
# If these don't match, you'll get 401 Unauthorized errors
# This is the #1 cause of setup failures.
CI_UPLOAD_SIGNING_KEY=
# ⚠️  TWO-LOCATION REQUIREMENT: This exact value must also be added as a
# GitHub repository secret named CI_UPLOAD_SIGNING_KEY. If they do not match,
# scan results will fail to upload with a 401 error. This is the #1 setup failure.

# ============================================
# GOOGLE CLOUD (OAuth + APIs)
# ============================================
# Create at: https://console.cloud.google.com/apis/credentials
# Guide: docs/google-oauth.md

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# GOOGLE ANALYTICS 4
# ============================================
# Guide: docs/google-analytics.md

GOOGLE_ANALYTICS_PROPERTY_ID=properties/123456789
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# ⚠️  MUST be a single line. Use: cat keyfile.json | jq -c .
# The \n sequences in the private_key field must remain as literal \n characters.
# Do NOT paste multi-line JSON here — authentication will fail silently.

# ============================================
# ANTHROPIC (AI Insights)
# ============================================
# Create account: https://console.anthropic.com/
# Cost: ~$5/month for daily scans
# This is core functionality - provides AI-powered SEO insights

ANTHROPIC_API_KEY=sk-ant-
AI_MODEL=claude-3-5-haiku-20241022
# If this model is deprecated, find the current name at:
# https://docs.anthropic.com/en/docs/about-claude/models

# ============================================
# DATAFORSEO (Competitor Analysis)
# ============================================
# Create account: https://dataforseo.com/
# Cost: $50 minimum deposit (lasts months for typical usage)
# Guide: docs/dataforseo.md
# This is core functionality - provides competitor SERP tracking

DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_LOCATION_CODE=2840
# ⚠️  2840 = United States. This affects ALL competitor and keyword data.
# If your website targets a non-US audience, change this BEFORE your first scan.
# Find your code at: https://docs.dataforseo.com/v3/appendix/locations_and_languages/
# Common codes: 2826 (UK), 2124 (Canada), 2036 (Australia), 2276 (Germany)
DATAFORSEO_LANGUAGE_CODE=en

# ============================================
# VERCEL KV (Database)
# ============================================
# Auto-populated when you add Vercel KV to your project
# Guide: docs/vercel-kv-setup.md

KV_REST_API_URL=
KV_REST_API_TOKEN=

# ============================================
# OPTIONAL: APPLICATION BRANDING
# ============================================
# Customize the dashboard appearance

# APP_NAME=Lighthouse Dashboard
# SITE_DESCRIPTION=Performance monitoring for your website

# Advanced branding (see docs/branding.md)
# NEXT_PUBLIC_BRAND_NAME=My Performance Dashboard
# NEXT_PUBLIC_BRAND_LOGO_PATH=/brand/logo.svg
# NEXT_PUBLIC_BRAND_FAVICON_PATH=/brand/favicon.svg
# NEXT_PUBLIC_BRAND_PRIMARY=#0B3D91
# NEXT_PUBLIC_BRAND_ACCENT=#B45309

# ============================================
# OPTIONAL: AUTHENTICATION RESTRICTION
# ============================================
# Restrict sign-in to a specific email domain
# Leave blank to allow any Google account

# ALLOWED_EMAIL_DOMAIN=

# ============================================
# OPTIONAL: SLACK NOTIFICATIONS
# ============================================
# Receive alerts for scans and regressions
# Detailed setup guide: docs/slack.md

# SLACK_WEBHOOK_URL=

# ============================================
# OPTIONAL: MANUAL SCAN TRIGGERS
# ============================================
# Enable "Trigger Scan" button in dashboard UI
# Requires GitHub Personal Access Token with 'repo' scope
# Detailed setup: docs/github-actions.md (Dashboard Trigger Button section)

# GITHUB_TOKEN=
# GITHUB_REPO_OWNER=your-username
# GITHUB_REPO_NAME=lighthouse-public

# ============================================
# OPTIONAL: AUTO-REDEPLOY
# ============================================
# Automatically redeploy dashboard after scans
# Detailed setup: docs/github-actions.md (Auto-Redeploy Dashboard section)

# VERCEL_DEPLOY_HOOK=

# ============================================
# OPTIONAL: DATAFORSEO CONFIGURATION
# ============================================
# Advanced DataForSEO settings

# Location code for SERP queries (default: 2840 = USA)
# See: https://docs.dataforseo.com/v3/appendix/locations_and_languages/
# Common: 2840 (USA), 2826 (UK), 2124 (Canada), 2036 (Australia)
# DATAFORSEO_LOCATION_CODE=2840

# Language code (default: en = English)
# Common: en, es, de, fr, pt, it, nl, ja, zh
# DATAFORSEO_LANGUAGE_CODE=en

# ============================================
# ADVANCED: SCANNING CONFIGURATION
# ============================================
# Adjust these only if you have specific needs

# How many points drop triggers regression alert (default: 10)
# REGRESSION_THRESHOLD=10

# How many scan runs to keep in local storage (default: 14)
# Note: Vercel KV stores last 30 runs separately
# KEEP_RUNS=14

# Maximum runs to keep in Vercel KV (default: 30, range: 1-365)
# REPORTS_MAX_RUNS=30
